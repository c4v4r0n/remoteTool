# --- Build output ----------------------------------------------------------
# `make` puts the binary, .o files, and -MMD .d dep files under /build at
# the repo root. setup.sh stages the patched FreeRDP source and its cmake
# build tree under /.freerdp-build.
/build/
/.freerdp-build/

# --- C build artifacts (catch-all, anywhere in tree) -----------------------
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.d
*.gch
*.lo
*.la

# Core dumps from crashes (gdb, valgrind). Be specific - bare `core`
# would also match the include/core/ source directory.
/core
core.[0-9]*
vgcore.*

# Coverage data, in case anyone runs gcov.
*.gcda
*.gcno
*.gcov
/coverage/

# clangd / language-server caches.
compile_commands.json
.cache/
.clangd/

# --- Editor / IDE ----------------------------------------------------------
*.swp
*.swo
*~
.*.swp
.DS_Store

.vscode/
.idea/
*.iml

# --- Claude Code -----------------------------------------------------------
# Per-project Claude Code state and instructions: keep these local to each
# developer's machine instead of committing them.
.claude/
CLAUDE.md

# --- User data (NEVER commit) ---------------------------------------------
# SQLite DBs may carry connection profiles; libsecret keeps the actual
# passwords, but hostnames + usernames are still sensitive. Be defensive
# in case anyone copies their ~/.config/remoteTool/connections.db into
# the repo for "easy testing".
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# --- Misc ------------------------------------------------------------------
*.bak
*.tmp
*.orig
*.rej
